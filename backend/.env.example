# Google Gemini API Keys (minimum 1 required — used as fallback for fake news, primary for image/research/weather)
# Get yours at https://aistudio.google.com/
GEMINI_API_KEY_1=your_api_key_1
GEMINI_API_KEY_2=your_api_key_2
GEMINI_API_KEY_3=your_api_key_3

# Groq API Key (recommended — enables instant fake news detection via Llama)
# Get yours free at https://console.groq.com/
GROQ_API_KEY=gsk_your_groq_api_key

# Server Port
PORT=3000

# Frontend URL for CORS (comma-separated for multiple origins)
# For production: FRONTEND_URL=https://your-app.vercel.app
FRONTEND_URL=http://localhost:5174
