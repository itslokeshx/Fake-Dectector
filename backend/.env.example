# Google Gemini API Keys (minimum 1 required — used as fallback for fake news, primary for image/research/weather)
# Get yours at https://aistudio.google.com/
GEMINI_API_KEY_1=your_gemini_key_1
GEMINI_API_KEY_2=your_gemini_key_2
GEMINI_API_KEY_3=your_gemini_key_3

# Groq API Keys — 3-key rotation (recommended — enables instant fake news via Llama 3.3 70B)
# Get yours free at https://console.groq.com/ (30 RPM per key, 3 keys = 90 RPM headroom)
GROQ_API_KEY_1=gsk_your_groq_key_1
GROQ_API_KEY_2=gsk_your_groq_key_2
GROQ_API_KEY_3=gsk_your_groq_key_3

# Server Port
PORT=3000

# Frontend URL for CORS (comma-separated for multiple origins)
# For production: FRONTEND_URL=https://your-app.vercel.app
FRONTEND_URL=http://localhost:5174
